{
    "name": "baizy/theme",
    "description": "Baizy WordPress Theme",
    "type": "wordpress-theme",
    "license": "GPL-2.0-or-later",
    "authors": [{
        "name": "Y.U."
    }],
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "Baizy\\": "app/"
        },
        "classmap": [
            "app/setup/",
            "app/models/",
            "app/controllers/",
            "app/helpers/",
            "app/services/",
            "app/widgets/"
        ],
        "files": [
            "app/functions/settings.php",
            "app/functions/my_functions.php",
            "app/functions/seo.php",
            "app/functions/admin.php",
            "app/functions/post_types.php",
            "app/functions/pagination.php",
            "app/functions/taxonomy_display.php",
            "app/functions/excerpt.php",
            "app/functions/term_color.php",
            "app/functions/global_links.php",
            "app/functions/widget.php",
            "app/functions/custom_block.php",
            "app/functions/plugins.php",
            "app/functions/comment.php",
            "app/functions/acf_json_export.php"
        ]
    }
}